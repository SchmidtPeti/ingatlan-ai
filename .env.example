# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Scraping céloldal
SEARCH_URL=https://ingatlan.com/lista/kiado+lakas+havi-100-180-ezer-Ft+budapest
MAX_PAGES=5
MAX_LISTINGS=60
SCRAPE_DELAY_MS=2000
BLOCK_CONSECUTIVE_THRESHOLD=3
BLOCK_RATE_THRESHOLD=0.40
BLOCK_RATE_MIN_ATTEMPTS=10

# Human-in-the-loop challenge handling
HITL_ENABLED=true
HITL_HEADFUL=true
HITL_PAUSE_TIMEOUT_SEC=900
HITL_MAX_PAUSES_PER_RUN=2
HITL_RESUME_RECHECK_WAIT_MS=1200
MANUAL_RESUME_RETRIES_PER_LISTING=1

# AI elemzés
TOP_N_PRESELECT=15
TOP_N_FINAL=5
AI_MODEL=claude-opus-4-5

# Scheduler (reggel 8:00)
CRON_SCHEDULE=0 8 * * *

# Szerver
PORT=3000

# Szűrési preferenciák (AI promptba kerül)
PREFERENCES=min 40nm, legalabb 1 haloszoba, nem fold szint, lift elonyt, 7. kerulettol tavol
