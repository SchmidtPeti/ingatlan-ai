{
  "name": "ingatlan-ai",
  "version": "1.0.0",
  "description": "Budapest ingatlan scraper és AI elemző webapp",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "scrape": "node -e \"require('./scraper').run().then(r => console.log('Scraped:', (r.listings || r).length, 'listings')).catch(console.error)\"",
    "analyze": "node -e \"require('./analyzer').run().then(console.log).catch(console.error)\"",
    "install:browsers": "npx playwright install chromium",
    "test:scraper": "node --test tests/scraper-utils.test.js tests/scraper-hitl.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@google/genai": "^1.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "playwright": "^1.49.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
